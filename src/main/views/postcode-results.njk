{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% extends "template.njk" %}

{% block pageTitle %}
  {{ title }}
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">
    <h1 class="govuk-heading-l">
      {{ question }}
    </h1>
    <div class="govuk-grid-column-two-thirds">
      <div class="govuk-grid-row">
        {% if isDivorceOrCivil %}
          <div>
            <p class="govuk-body-m">
              {% if serviceArea === 'divorce' %}
                {{ divorceHint }}
              {% else %}
                {{ civilHint }}
              {% endif %}
               {{ secondHint }}
              <br>
              {{ thirdHint }}
            </p>
          </div>
          <div class="search-result">
            <h2 class="govuk-heading-m">
              <a class="govuk-link" href="/courts/{{ results.courts[0].slug }}">{{ results.courts[0].name }}</a>
            </h2>
          </div>
        {% else %}
          <div>
            {% if postcodeOnlySearch %}
              <p class="govuk-body-m">
                {{ postcodeSearchResultsHint }}
              </p>
            {% else %}
              <p class="govuk-body-m">
                {{ singleResultsHint if results.courts.length === 1 else multipleResultsHint }}
              </p>
            {% endif %}

          </div>
          {% if postcodeOnlySearch %}
            {% set currentCourts = results.courts or [] %}
            {% set accurateCourts = (newResults and newResults.courts) or [] %}
            <div class="govuk-tabs" data-module="govuk-tabs">
              <h2 class="govuk-tabs__title">Results view</h2>
              <ul class="govuk-tabs__list">
                <li class="govuk-tabs__list-item govuk-tabs__list-item--selected">
                  <a class="govuk-tabs__tab" href="#tab-current">Current</a>
                </li>
                <li class="govuk-tabs__list-item">
                  <a class="govuk-tabs__tab" href="#tab-new">New</a>
                </li>
              </ul>
              <div class="govuk-tabs__panel" id="tab-current">
                <div id="search-results">
                  {% for court in currentCourts %}
                  <div class="govuk-grid-row">
                    <div class="govuk-grid-column-three-quarters">
                      <h2 class="govuk-heading-m">
                        <a class="govuk-link" href="/courts/{{ court.slug }}">{{ court.name }}</a>
                      </h2>
                    </div>
                    <div class="govuk-grid-column-one-quarter distance">
                      <p class="govuk-body-m">
                        {% if court.distanceMiles is defined %}
                          {{ court.distanceMiles.toFixed(1) }} {{ unit }}
                        {% elseif court.distance is defined %}
                          {{ court.distance.toFixed(1) }} {{ unit }}
                        {% endif %}
                      </p>
                    </div>
                  </div>
                  {% endfor %}
                </div>
              </div>
              <div class="govuk-tabs__panel govuk-tabs__panel--hidden" id="tab-new">
                <div id="search-results-new">
                  {% for court in accurateCourts %}
                  <div class="govuk-grid-row">
                    <div class="govuk-grid-column-three-quarters">
                      <h2 class="govuk-heading-m">
                        <a class="govuk-link" href="/courts/{{ court.slug }}">{{ court.name }}</a>
                      </h2>
                    </div>
                    <div class="govuk-grid-column-one-quarter distance">
                      <p class="govuk-body-m">
                        {% if court.distanceMiles is defined %}
                          {{ court.distanceMiles.toFixed(1) }} {{ unit }}
                        {% elseif court.distance is defined %}
                          {{ court.distance.toFixed(1) }} {{ unit }}
                        {% endif %}
                      </p>
                    </div>
                  </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          {% else %}
            <div id="search-results">
              {% for court in results.courts %}
              <div class="govuk-grid-row">
                <div class="govuk-grid-column-three-quarters">
                  <h2 class="govuk-heading-m">
                    <a class="govuk-link" href="/courts/{{ court.slug }}">{{ court.name }}</a>
                  </h2>
                </div>
                <div class="govuk-grid-column-one-quarter distance">
                  <p class="govuk-body-m">
                    {% if court.distanceMiles is defined %}
                      {{ court.distanceMiles.toFixed(1) }} {{ unit }}
                    {% elseif court.distance is defined %}
                      {{ court.distance.toFixed(1) }} {{ unit }}
                    {% endif %}
                  </p>
                </div>
              </div>
              {% endfor %}
            </div>
          {% endif %}
        {% endif %}
      </div>
    </div>
    {% if results.onlineText and results.onlineUrl %}
      <div class="govuk-grid-column-one-third side-content">
        <div id="areas-of-law">
          <h3 class="govuk-heading-m">
            {{ applyOnlineHeading }}
          </h3>
          <p class="govuk-body-m">
            <a class="govuk-link" href="{{ results.onlineUrl }}"> {{ results.onlineText }} </a>
          </p>
        </div>
      </div>
    {% endif %}
  </div>
</div>
{% endblock %}
